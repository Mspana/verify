{
    "name": "verify",
    "private": true,
    "version": "0.0.0",
    "workspaces": [
      "shared",
      "worker",
      "web"
    ],
    "scripts": {
      "dev:worker": "npm run dev -w worker",
      "dev:web": "npm run dev -w web",
